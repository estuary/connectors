[
  {
    "protocol": 3032023,
    "configSchema": {
      "$defs": {
        "GongCredentials": {
          "properties": {
            "credentials_title": {
              "const": "API Key",
              "default": "API Key",
              "title": "Credentials Title",
              "type": "string"
            },
            "access_key": {
              "description": "The Gong API Access Key.",
              "secret": true,
              "title": "Access Key",
              "type": "string"
            },
            "access_key_secret": {
              "description": "The Gong API Access Key Secret.",
              "secret": true,
              "title": "Access Key Secret",
              "type": "string"
            }
          },
          "required": [
            "access_key",
            "access_key_secret"
          ],
          "title": "GongCredentials",
          "type": "object"
        }
      },
      "properties": {
        "credentials": {
          "discriminator": {
            "mapping": {
              "API Key": "#/$defs/GongCredentials"
            },
            "propertyName": "credentials_title"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/GongCredentials"
            }
          ],
          "title": "Authentication"
        },
        "region": {
