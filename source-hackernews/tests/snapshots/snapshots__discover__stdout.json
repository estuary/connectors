              "title": "Row Id",
              "type": "integer"
            }
          },
          "title": "Meta",
          "type": "object"
        }
      },
      "additionalProperties": true,
      "description": "HackerNews Item model representing stories, comments, jobs, polls, and poll options.\nAll timestamps are converted from Unix time to datetime objects.",
      "properties": {
        "_meta": {
          "$ref": "#/$defs/Meta",
          "description": "Document metadata"
        },
        "id": {
          "description": "The item's unique id.",
          "title": "Id",
          "type": "integer"
        },
        "deleted": {
          "default": false,
          "description": "true if the item is deleted.",
          "title": "Deleted",
          "type": "boolean"
        },
        "type": {
          "description": "The type of item. One of \"job\", \"story\", \"comment\", \"poll\", or \"pollopt\".",
          "title": "Type",
          "type": "string"
        },
        "by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The username of the item's author.",
          "title": "By"
        },
        "time": {
          "description": "Creation date of the item, converted from Unix timestamp.",
          "format": "date-time",
          "title": "Time",
          "type": "string"
        },
        "text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The comment, story or poll text. HTML.",
          "title": "Text"
        },
        "dead": {
          "default": false,
          "description": "true if the item is dead.",
          "title": "Dead",
          "type": "boolean"
        },
        "parent": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The comment's parent: either another comment or the relevant story.",
          "title": "Parent"
        },
        "poll": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The pollopt's associated poll.",
          "title": "Poll"
        },
        "kids": {
          "description": "The ids of the item's comments, in ranked display order.",
          "items": {
            "type": "integer"
          },
          "title": "Kids",
          "type": "array"
        },
        "url": {
          "anyOf": [
            {
              "format": "uri",
              "maxLength": 2083,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The URL of the story.",
          "title": "Url"
        },
        "score": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The story's score, or the votes for a pollopt.",
          "title": "Score"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The title of the story, poll or job. HTML.",
          "title": "Title"
        },
        "parts": {
          "anyOf": [
            {
              "items": {
                "type": "integer"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "A list of related pollopts, in display order.",
          "title": "Parts"
        },
        "descendants": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "In the case of stories or polls, the total comment count.",
          "title": "Descendants"
        }
      },
      "required": [
        "id",
        "type",
        "time"
      ],
      "title": "Item",
      "type": "object",
      "x-infer-schema": true,
      "if": {
        "required": [
          "_meta"
        ],
        "properties": {
          "_meta": {
            "required": [
              "op"
            ],
            "properties": {
              "op": {
                "const": "d"
              }
            }
          }
        }
      },
      "then": {
        "reduce": {
          "strategy": "merge",
          "delete": true
        }
      }
    },
    "key": [
      "/id"
    ]
  },
