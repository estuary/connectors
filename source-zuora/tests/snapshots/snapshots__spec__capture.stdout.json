[
  {
    "protocol": 3032023,
    "configSchema": {
      "$defs": {
        "BaseURL": {
          "description": "Zuora REST API base URLs, one per data center and environment.\nhttps://developer.zuora.com/api-references/api/overview/#section/Introduction/Access-to-the-API",
          "enum": [
            "https://rest.zuora.com",
            "https://rest.apisandbox.zuora.com",
            "https://rest.test.zuora.com",
            "https://rest.pt1.zuora.com",
            "https://rest.na.zuora.com",
            "https://rest.sandbox.na.zuora.com",
            "https://rest.eu.zuora.com",
            "https://rest.sandbox.eu.zuora.com",
            "https://rest.test.eu.zuora.com",
            "https://rest.ap.zuora.com",
            "https://rest.test.ap.zuora.com"
          ],
          "title": "BaseURL",
          "type": "string"
        },
        "ClientCredentialsOAuth2Credentials": {
          "properties": {
            "credentials_title": {
              "const": "OAuth Credentials",
              "default": "OAuth Credentials",
              "title": "Credentials Title",
              "type": "string"
            },
            "client_id": {
              "secret": true,
              "title": "Client Id",
              "type": "string"
            },
            "client_secret": {
              "secret": true,
              "title": "Client Secret",
              "type": "string"
            }
          },
          "required": [
            "client_id",
            "client_secret"
          ],
          "title": "OAuth",
          "type": "object"
        }
      },
      "properties": {
        "credentials": {
          "$ref": "#/$defs/ClientCredentialsOAuth2Credentials"
        },
        "base_url": {
          "$ref": "#/$defs/BaseURL",
          "default": "https://rest.zuora.com",
          "description": "Zuora REST API base URL for your tenant's data center and environment.",
          "title": "API Base URL"
        },
        "start_date": {
          "description": "UTC date and time from which to start replicating data. Defaults to January 1, 2000, which captures all available history.",
          "format": "date-time",
          "title": "Start Date",
          "type": "string"
        }
      },
      "required": [
        "credentials"
      ],
      "title": "EndpointConfig",
      "type": "object"
    },
    "resourceConfigSchema": {
      "additionalProperties": false,
      "description": "ResourceConfig is a common resource configuration shape.",
      "properties": {
        "_meta": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Meta"
        },
        "name": {
          "description": "Name of this resource",
          "title": "Name",
          "type": "string"
        },
        "interval": {
          "default": "PT0S",
          "description": "Interval between updates for this resource",
          "format": "duration",
          "title": "Interval",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "ResourceConfig",
      "type": "object"
    },
    "documentationUrl": "https://go.estuary.dev/source-zuora",
    "resourcePathPointers": [
      "/name"
    ]
  }
]
