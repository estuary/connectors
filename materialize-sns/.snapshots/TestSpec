{
  "config_schema_json": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/estuary/connectors/materialize-sns/config",
    "properties": {
      "region": {
        "type": "string",
        "title": "AWS Region",
        "description": "Region of the SNS topics this materialization publishes to.",
        "order": 1
      },
      "credentials": {
        "oneOf": [
          {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "https://github.com/estuary/connectors/materialize-sns/access-key-credentials",
            "properties": {
              "auth_type": {
                "type": "string",
                "const": "AWSAccessKey",
                "default": "AWSAccessKey",
                "order": 0
              },
              "aws_access_key_id": {
                "type": "string",
                "title": "AWS Access Key ID",
                "description": "AWS Access Key ID for publishing to the SNS topics.",
                "order": 1
              },
              "aws_secret_access_key": {
                "type": "string",
                "title": "AWS Secret Access Key",
                "description": "AWS Secret Access Key for publishing to the SNS topics.",
                "order": 2,
                "secret": true
              }
            },
            "type": "object",
            "required": [
              "aws_access_key_id",
              "aws_secret_access_key"
            ],
            "title": "Access Key"
          },
          {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "https://github.com/estuary/connectors/go/auth/iam/aws-config",
            "properties": {
              "auth_type": {
                "type": "string",
                "const": "AWSIAM",
                "default": "AWSIAM",
                "order": 0
              },
              "aws_region": {
                "type": "string",
                "title": "AWS Region",
                "description": "AWS Region of your resource"
              },
              "aws_role_arn": {
                "type": "string",
                "title": "AWS Role ARN",
                "description": "AWS Role which has access to the resource which will be assumed by Flow"
              }
            },
            "type": "object",
            "required": [
              "aws_region",
              "aws_role_arn"
            ],
            "title": "AWS IAM"
          }
        ],
        "type": "object",
        "title": "Authentication",
        "default": {
          "auth_type": "AWSAccessKey"
        },
        "discriminator": {
          "propertyName": "auth_type"
        },
        "order": 2,
        "x-iam-auth": true
      },
      "advanced": {
        "properties": {
          "endpoint": {
            "type": "string",
            "title": "AWS Endpoint",
            "description": "Override the SNS endpoint URL."
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "Advanced Options",
        "description": "Options for advanced users. You should not typically need to modify these.",
        "advanced": true
      }
    },
    "type": "object",
    "required": [
      "region",
      "credentials"
    ],
    "title": "Materialize AWS SNS Spec"
  },
  "resource_config_schema_json": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/estuary/connectors/materialize-sns/resource",
    "properties": {
      "topic_name": {
        "type": "string",
        "title": "Topic Name",
        "description": "Name of the SNS topic to publish to (without the ARN prefix). FIFO topics must end in '.fifo'.",
        "x-collection-name": true
      }
    },
    "type": "object",
    "required": [
      "topic_name"
    ],
    "title": "AWS SNS Topic"
  },
  "documentation_url": "https://go.estuary.dev/materialize-sns"
}
