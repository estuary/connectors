{
  "config_schema_json": {
    "$defs": {
      "AccessKeyCredentials": {
        "properties": {
          "auth_type": {
            "const": "AWSAccessKey",
            "default": "AWSAccessKey",
            "order": 0,
            "title": "Auth Type",
            "type": "string"
          },
          "awsAccessKeyId": {
            "description": "Access Key ID for accessing AWS services.",
            "minLength": 1,
            "order": 1,
            "title": "AWS Access Key ID",
            "type": "string"
          },
          "awsSecretAccessKey": {
            "description": "Secret Access Key for accessing AWS services.",
            "minLength": 1,
            "order": 2,
            "secret": true,
            "title": "AWS Secret Access Key",
            "type": "string"
          }
        },
        "required": [
          "awsAccessKeyId",
          "awsSecretAccessKey"
        ],
        "title": "Access Key",
        "type": "object"
      },
      "AdvancedConfig": {
        "properties": {
          "feature_flags": {
            "default": null,
            "description": "This property is intended for Estuary internal use. You should only modify this field as directed by Estuary support.",
            "title": "Feature Flags",
            "type": [
              "string",
              "null"
            ]
          }
        },
        "title": "AdvancedConfig",
        "type": "object"
      },
      "GlueCatalogConfig": {
        "properties": {
          "catalog_type": {
            "const": "AWS Glue",
            "default": "AWS Glue",
            "title": "Catalog Type",
            "type": "string"
          },
          "glue_id": {
            "default": null,
            "description": "Glue Catalog ID to use. If not specified, defaults to the account ID of the configured credentials.",
            "order": 1,
            "title": "Glue Catalog ID",
            "type": [
              "string",
              "null"
            ]
          }
        },
        "title": "AWS Glue",
        "type": "object"
      },
      "IAMCredentials": {
        "properties": {
          "auth_type": {
            "const": "AWSIAM",
            "default": "AWSIAM",
            "order": 0,
            "title": "Auth Type",
            "type": "string"
          },
          "aws_region": {
            "description": "AWS Region of your resource.",
            "minLength": 1,
            "order": 1,
            "title": "AWS Region",
            "type": "string"
          },
          "aws_role_arn": {
            "description": "AWS Role which has access to the resource which will be assumed by Flow.",
            "minLength": 1,
            "order": 2,
            "title": "AWS Role ARN",
            "type": "string"
          },
          "aws_access_key_id": {
            "default": "",
            "description": "AWS Access Key ID for accessing AWS services.",
            "order": 3,
            "title": "AWS Access Key ID",
            "type": "string",
            "x-hidden-field": true
          },
          "aws_secret_access_key": {
            "default": "",
            "description": "AWS Secret Access Key for accessing AWS services.",
            "order": 4,
            "title": "AWS Secret Access Key",
            "type": "string",
            "x-hidden-field": true
          },
          "aws_session_token": {
            "default": "",
            "description": "AWS Session Token for accessing AWS services.",
            "order": 5,
            "title": "AWS Session Token",
            "type": "string",
            "x-hidden-field": true
          }
        },
        "required": [
          "aws_region",
          "aws_role_arn"
        ],
        "title": "AWS IAM",
        "type": "object"
      },
      "RestCatalogConfig": {
        "properties": {
          "catalog_type": {
            "const": "Iceberg REST Server",
            "default": "Iceberg REST Server",
            "order": 0,
            "title": "Catalog Type",
            "type": "string"
          },
          "uri": {
            "description": "URI identifying the REST catalog, in the format of 'https://yourserver.com/catalog'.",
            "order": 1,
            "title": "URI",
            "type": "string"
          },
          "credential": {
            "default": null,
            "description": "Credential for connecting to the catalog.",
            "order": 2,
            "secret": true,
            "title": "Credential",
            "type": [
              "string",
              "null"
            ]
          },
          "token": {
            "default": null,
            "description": "Token for connecting to the catalog.",
            "order": 3,
            "secret": true,
            "title": "Token",
            "type": [
              "string",
              "null"
            ]
          },
          "warehouse": {
            "description": "Warehouse to connect to.",
            "order": 4,
            "title": "Warehouse",
            "type": "string"
          }
        },
        "required": [
          "uri",
          "warehouse"
        ],
        "title": "REST",
        "type": "object"
      }
    },
    "properties": {
      "aws_access_key_id": {
        "default": null,
        "description": "Access Key ID for accessing AWS services.",
        "order": 0,
        "title": "AWS Access Key ID",
        "type": [
          "string",
          "null"
        ],
        "x-hidden-field": true
      },
      "aws_secret_access_key": {
        "default": null,
        "description": "Secret Access Key for accessing AWS services.",
        "order": 1,
        "secret": true,
        "title": "AWS Secret Access Key",
        "type": [
          "string",
          "null"
        ],
        "x-hidden-field": true
      },
      "credentials": {
        "default": {
          "auth_type": "AWSAccessKey"
        },
        "discriminator": {
          "mapping": {
            "AWSAccessKey": "#/$defs/AccessKeyCredentials",
            "AWSIAM": "#/$defs/IAMCredentials"
          },
          "propertyName": "auth_type"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/AccessKeyCredentials"
          },
          {
            "$ref": "#/$defs/IAMCredentials"
          }
        ],
        "order": 2,
        "title": "Authentication",
        "x-iam-auth": true
      },
      "bucket": {
        "description": "The S3 bucket to write data files to.",
        "order": 3,
        "title": "Bucket",
        "type": "string"
      },
      "prefix": {
        "default": "",
        "description": "Optional prefix that will be used to store objects.",
        "order": 4,
        "title": "Prefix",
        "type": "string"
      },
      "region": {
        "description": "AWS region.",
        "order": 5,
        "title": "Region",
        "type": "string"
      },
      "namespace": {
        "description": "Namespace for bound collection tables (unless overridden within the binding resource configuration).",
        "order": 6,
        "pattern": "^[^.]*$",
        "title": "Namespace",
        "type": "string"
      },
      "upload_interval": {
        "default": "PT5M",
        "description": "Frequency at which files will be uploaded. Must be a valid ISO8601 duration string no greater than 4 hours.",
        "format": "duration",
        "order": 7,
        "title": "Upload Interval",
        "type": "string"
      },
      "s3_endpoint": {
        "default": "",
        "description": "Custom S3 endpoint URL. If not provided, the default AWS S3 endpoint for the specified region will be used.",
        "order": 8,
        "title": "S3 Endpoint",
        "type": "string"
      },
      "catalog": {
        "discriminator": {
          "mapping": {
            "AWS Glue": "#/$defs/GlueCatalogConfig",
            "Iceberg REST Server": "#/$defs/RestCatalogConfig"
          },
          "propertyName": "catalog_type"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/RestCatalogConfig"
          },
          {
            "$ref": "#/$defs/GlueCatalogConfig"
          }
        ],
        "order": 9,
        "title": "Catalog"
      },
      "advanced": {
        "advanced": true,
        "anyOf": [
          {
            "$ref": "#/$defs/AdvancedConfig"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Options for advanced users. You should not typically need to modify these.",
        "order": 10,
        "title": "Advanced Options"
      }
    },
    "required": [
      "bucket",
      "region",
      "namespace",
      "catalog"
    ],
    "title": "EndpointConfig",
    "type": "object"
  },
  "resource_config_schema_json": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/estuary/connectors/materialize-s3-iceberg/resource",
    "properties": {
      "table": {
        "type": "string",
        "title": "Table",
        "description": "Name of the database table.",
        "x-collection-name": true
      },
      "namespace": {
        "type": "string",
        "title": "Alternative Namespace",
        "description": "Alternative namespace for this table (optional)."
      },
      "delta_updates": {
        "type": "boolean",
        "title": "Delta Update",
        "description": "Should updates to this table be done via delta updates. Currently this connector only supports delta updates.",
        "default": true
      }
    },
    "type": "object",
    "required": [
      "table"
    ],
    "title": "ResourceConfig"
  },
  "documentation_url": "https://go.estuary.dev/materialize-s3-iceberg"
}
