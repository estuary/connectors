{
  "config_schema_json": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/estuary/connectors/materialize-s3-iceberg/config",
    "properties": {
      "aws_access_key_id": {
        "oneOf": [
          {
            "type": "string",
            "title": "AWS Access Key ID",
            "description": "Access Key ID for accessing AWS services (legacy).",
            "order": 0,
            "x-hidden-field": true
          },
          {
            "type": "null"
          }
        ]
      },
      "aws_secret_access_key": {
        "oneOf": [
          {
            "type": "string",
            "title": "AWS Secret Access Key",
            "description": "Secret Access Key for accessing AWS services (legacy).",
            "order": 1,
            "secret": true,
            "x-hidden-field": true
          },
          {
            "type": "null"
          }
        ]
      },
      "credentials": {
        "oneOf": [
          {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "https://github.com/estuary/connectors/filesink/access-key-credentials",
            "properties": {
              "auth_type": {
                "type": "string",
                "const": "AWSAccessKey",
                "default": "AWSAccessKey",
                "order": 0
              },
              "awsAccessKeyId": {
                "type": "string",
                "title": "AWS Access Key ID",
                "description": "Access Key ID for writing data to the bucket.",
                "order": 1
              },
              "awsSecretAccessKey": {
                "type": "string",
                "title": "AWS Secret Access key",
                "description": "Secret Access Key for writing data to the bucket.",
                "order": 2,
                "secret": true
              }
            },
            "type": "object",
            "required": [
              "awsAccessKeyId",
              "awsSecretAccessKey"
            ],
            "title": "Access Key"
          },
          {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "https://github.com/estuary/connectors/go/auth/iam/aws-config",
            "properties": {
              "auth_type": {
                "type": "string",
                "const": "AWSIAM",
                "default": "AWSIAM",
                "order": 0
              },
              "aws_region": {
                "type": "string",
                "title": "AWS Region",
                "description": "AWS Region of your resource"
              },
              "aws_role_arn": {
                "type": "string",
                "title": "AWS Role ARN",
                "description": "AWS Role which has access to the resource which will be assumed by Flow"
              }
            },
            "type": "object",
            "required": [
              "aws_region",
              "aws_role_arn"
            ],
            "title": "AWS IAM"
          }
        ],
        "type": "object",
        "title": "Authentication",
        "default": {
          "auth_type": "AWSAccessKey"
        },
        "discriminator": {
          "propertyName": "auth_type"
        },
        "order": 2,
        "x-iam-auth": true
      },
      "bucket": {
        "type": "string",
        "title": "Bucket",
        "description": "The S3 bucket to write data files to.",
        "order": 3
      },
      "prefix": {
        "type": "string",
        "title": "Prefix",
        "description": "Optional prefix that will be used to store objects.",
        "order": 4
      },
      "region": {
        "type": "string",
        "title": "Region",
        "description": "AWS region.",
        "order": 5
      },
      "namespace": {
        "type": "string",
        "title": "Namespace",
        "description": "Namespace for bound collection tables (unless overridden within the binding resource configuration).",
        "order": 6,
        "pattern": "^[^.]*$"
      },
      "upload_interval": {
        "type": "string",
        "title": "Upload Interval",
        "description": "Frequency at which files will be uploaded. Must be a valid ISO8601 duration string no greater than 4 hours.",
        "default": "PT5M",
        "order": 7
      },
      "s3_endpoint": {
        "type": "string",
        "title": "S3 Endpoint",
        "description": "Custom S3 endpoint URL. The default AWS S3 endpoint for the specified region is used if not provided.",
        "order": 8
      },
      "catalog": {
        "oneOf": [
          {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "https://github.com/estuary/connectors/materialize-s3-iceberg/rest-catalog-props",
            "properties": {
              "catalog_type": {
                "type": "string",
                "const": "Iceberg REST Server",
                "default": "Iceberg REST Server",
                "order": 0
              },
              "uri": {
                "type": "string",
                "title": "URI",
                "description": "URI identifying the REST catalog. Format: 'https://yourserver.com/catalog'.",
                "order": 1
              },
              "credential": {
                "oneOf": [
                  {
                    "type": "string",
                    "title": "Credential",
                    "description": "Credential for connecting to the catalog.",
                    "order": 2,
                    "secret": true
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "token": {
                "oneOf": [
                  {
                    "type": "string",
                    "title": "Token",
                    "description": "Token for connecting to the catalog.",
                    "order": 3,
                    "secret": true
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "warehouse": {
                "type": "string",
                "title": "Warehouse",
                "description": "Warehouse to connect to.",
                "order": 4
              },
              "scope": {
                "oneOf": [
                  {
                    "type": "string",
                    "title": "Scope",
                    "description": "Desired scope of the requested security token.",
                    "order": 5
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "type": "object",
            "required": [
              "uri",
              "warehouse"
            ],
            "title": "REST"
          },
          {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "https://github.com/estuary/connectors/materialize-s3-iceberg/glue-catalog-props",
            "properties": {
              "catalog_type": {
                "type": "string",
                "const": "AWS Glue",
                "default": "AWS Glue",
                "order": 0
              },
              "glue_id": {
                "oneOf": [
                  {
                    "type": "string",
                    "title": "Glue Catalog ID",
                    "description": "Glue Catalog ID to use. Defaults to the account ID of the configured credentials when not set.",
                    "order": 1
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "type": "object",
            "title": "AWS Glue"
          }
        ],
        "type": "object",
        "title": "Catalog",
        "default": {
          "catalog_type": "Iceberg REST Server"
        },
        "discriminator": {
          "propertyName": "catalog_type"
        },
        "order": 9
      },
      "advanced": {
        "properties": {
          "feature_flags": {
            "oneOf": [
              {
                "type": "string",
                "title": "Feature Flags",
                "description": "This property is intended for Estuary internal use. You should only modify this field as directed by Estuary support."
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "Advanced Options",
        "description": "Options for advanced users. You should not typically need to modify these.",
        "advanced": true,
        "order": 10
      }
    },
    "type": "object",
    "required": [
      "bucket",
      "region",
      "namespace",
      "upload_interval",
      "catalog"
    ],
    "title": "EndpointConfig"
  },
  "resource_config_schema_json": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/estuary/connectors/materialize-s3-iceberg/resource",
    "properties": {
      "table": {
        "type": "string",
        "title": "Table",
        "description": "Name of the database table.",
        "x-collection-name": true
      },
      "namespace": {
        "type": "string",
        "title": "Alternative Namespace",
        "description": "Alternative namespace for this table (optional)."
      },
      "delta_updates": {
        "type": "boolean",
        "title": "Delta Update",
        "description": "Should updates to this table be done via delta updates. Currently this connector only supports delta updates.",
        "default": true
      },
      "additional_table_properties": {
        "additionalProperties": {
          "type": "string"
        },
        "type": "object",
        "title": "Additional Table Properties",
        "description": "Additional Iceberg table properties to set when the table is created. These are set only at creation time and cannot be changed afterwards. Example: {'write.parquet.compression-codec': 'zstd'}"
      }
    },
    "type": "object",
    "required": [
      "table"
    ],
    "title": "ResourceConfig"
  },
  "documentation_url": "https://go.estuary.dev/materialize-s3-iceberg"
}
