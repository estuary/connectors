[
  {
    "protocol": 3032023,
    "configSchema": {
      "$defs": {
        "ApiAccessToken": {
          "properties": {
            "credentials_title": {
              "const": "API Access Token",
              "default": "API Access Token",
              "order": 0,
              "title": "Credentials Title",
              "type": "string"
            },
            "access_token": {
              "description": "Smartsheet API Access Token, generated under Account > Apps & Integrations > API Access.",
              "order": 1,
              "secret": true,
              "title": "API Access Token",
              "type": "string"
            }
          },
          "required": [
            "access_token"
          ],
          "title": "ApiAccessToken",
          "type": "object"
        }
      },
      "properties": {
        "start_date": {
          "description": "UTC date and time in the format YYYY-MM-DDTHH:MM:SSZ. Any data generated before this date will not be replicated. If left blank, the start date will be set to 30 days before the present.",
          "format": "date-time",
          "title": "Start Date",
          "type": "string"
        },
        "region": {
          "default": "us",
          "description": "The Smartsheet data center your account is hosted in. Determines the API base URL used to reach your account.",
          "enum": [
            "us",
            "eu",
            "gov",
            "au"
          ],
          "title": "Region",
          "type": "string"
        },
        "credentials": {
          "discriminator": {
            "mapping": {
              "API Access Token": "#/$defs/ApiAccessToken"
            },
            "propertyName": "credentials_title"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/ApiAccessToken"
            }
          ],
          "title": "Authentication"
        }
      },
      "required": [
        "credentials"
      ],
      "title": "EndpointConfig",
      "type": "object"
    },
    "resourceConfigSchema": {
      "additionalProperties": false,
      "properties": {
        "_meta": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Meta"
        },
        "name": {
          "description": "Name of this resource",
          "title": "Name",
          "type": "string"
        },
        "interval": {
          "default": "PT0S",
          "description": "Interval between updates for this resource",
          "format": "duration",
          "title": "Interval",
          "type": "string"
        },
        "schedule": {
          "default": "",
          "description": "Schedule to automatically rebackfill this binding. Accepts a cron expression.",
          "pattern": "^((?:[0-5]?\\d(?:-[0-5]?\\d)?|\\*(?:/[0-5]?\\d)?)(?:,(?:[0-5]?\\d(?:-[0-5]?\\d)?|\\*(?:/[0-5]?\\d)?))*)\\s+((?:[01]?\\d|2[0-3]|(?:[01]?\\d|2[0-3])-(?:[01]?\\d|2[0-3])|\\*(?:/[01]?\\d|/2[0-3])?)(?:,(?:[01]?\\d|2[0-3]|(?:[01]?\\d|2[0-3])-(?:[01]?\\d|2[0-3])|\\*(?:/[01]?\\d|/2[0-3])?))*)\\s+((?:0?[1-9]|[12]\\d|3[01]|(?:0?[1-9]|[12]\\d|3[01])-(?:0?[1-9]|[12]\\d|3[01])|\\*(?:/[0-9]|/1[0-9]|/2[0-9]|/3[01])?)(?:,(?:0?[1-9]|[12]\\d|3[01]|(?:0?[1-9]|[12]\\d|3[01])-(?:0?[1-9]|[12]\\d|3[01])|\\*(?:/[0-9]|/1[0-9]|/2[0-9]|/3[01])?))*)\\s+((?:[1-9]|1[0-2]|(?:[1-9]|1[0-2])-(?:[1-9]|1[0-2])|\\*(?:/[1-9]|/1[0-2])?)(?:,(?:[1-9]|1[0-2]|(?:[1-9]|1[0-2])-(?:[1-9]|1[0-2])|\\*(?:/[1-9]|/1[0-2])?))*)\\s+((?:[0-6]|(?:[0-6])-(?:[0-6])|\\*(?:/[0-6])?)(?:,(?:[0-6]|(?:[0-6])-(?:[0-6])|\\*(?:/[0-6])?))*)$|^$",
          "title": "Schedule",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "ResourceConfigWithSchedule",
      "type": "object"
    },
    "documentationUrl": "https://go.estuary.dev/source-smartsheet",
    "resourcePathPointers": [
      "/name"
    ]
  }
]
