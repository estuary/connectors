[
  {
    "protocol": 3032023,
    "configSchema": {
      "$defs": {
        "AccessToken": {
          "properties": {
            "credentials_title": {
              "const": "Private App Credentials",
              "default": "Private App Credentials",
              "title": "Credentials Title",
              "type": "string"
            },
            "access_token": {
              "secret": true,
              "title": "Access Token",
              "type": "string"
            }
          },
          "required": [
            "access_token"
          ],
          "title": "AccessToken",
          "type": "object"
        },
        "Advanced": {
          "properties": {
            "window_size": {
              "default": "P7D",
              "description": "Date window size for the events backfill in ISO 8601 format. ex: P30D means 30 days, PT6H means 6 hours.",
              "format": "duration",
              "title": "Window size",
              "type": "string"
            }
          },
          "title": "Advanced",
          "type": "object"
        },
        "Dataset": {
          "enum": [
            "spans",
            "errors",
            "transactions"
          ],
          "title": "Dataset",
          "type": "string"
        },
        "ExploreQuery": {
          "properties": {
            "name": {
              "description": "Name for this Explore query stream. The connector prefixes it with 'custom_explore_' to form the stream name.",
              "minLength": 1,
              "title": "Name",
              "type": "string"
            },
            "dataset": {
              "$ref": "#/$defs/Dataset",
              "description": "Dataset to query. Can be one of 'spans', 'errors', or 'transactions'."
            },
            "fields": {
              "description": "Comma-separated field list to return, e.g. 'span.description, transaction, project'. The dataset's primary key fields and 'timestamp' are added automatically.",
              "title": "Fields",
              "type": "string"
            },
            "query": {
              "default": "",
              "description": "Optional Sentry search query to filter rows. The connector manages the time window itself, so a 'timestamp:' clause is not allowed.",
              "title": "Query",
              "type": "string"
            },
            "projects": {
              "default": "",
              "description": "Comma-separated project IDs to include. Leave empty to query all projects.",
              "title": "Projects",
              "type": "string"
            }
          },
          "required": [
            "name",
            "dataset",
            "fields"
          ],
          "title": "ExploreQuery",
          "type": "object"
        }
      },
      "properties": {
        "organization": {
          "description": "Organization to Request Data From",
          "order": 0,
          "title": "Organization",
          "type": "string"
        },
        "credentials": {
          "discriminator": {
            "mapping": {
              "Private App Credentials": "#/$defs/AccessToken"
            },
            "propertyName": "credentials_title"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/AccessToken"
            }
          ],
          "order": 1,
          "title": "Authentication"
        },
        "start_date": {
          "description": "UTC date and time in the format YYYY-MM-DDTHH:MM:SSZ. Any data generated before this date will not be replicated. If left blank, the start date will be set to 30 days before the present.",
          "format": "date-time",
          "order": 2,
          "title": "Start Date",
          "type": "string"
        },
        "explore_queries": {
          "advanced": true,
          "description": "User-defined explore query streams. Each entry becomes its own incremental stream backed by Sentry's Explore events endpoint.",
          "items": {
            "$ref": "#/$defs/ExploreQuery"
          },
          "order": 3,
          "title": "Explore Queries",
          "type": "array"
        },
        "advanced": {
          "$ref": "#/$defs/Advanced",
          "advanced": true,
          "description": "Advanced settings for the connector.",
          "order": 4,
          "title": "Advanced Config"
        }
      },
      "required": [
        "organization",
        "credentials"
      ],
      "title": "EndpointConfig",
      "type": "object"
    },
    "resourceConfigSchema": {
      "additionalProperties": false,
      "description": "ResourceConfig is a common resource configuration shape.",
      "properties": {
        "_meta": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Meta"
        },
        "name": {
          "description": "Name of this resource",
          "title": "Name",
          "type": "string"
        },
        "interval": {
          "default": "PT0S",
          "description": "Interval between updates for this resource",
          "format": "duration",
          "title": "Interval",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "ResourceConfig",
      "type": "object"
    },
    "documentationUrl": "https://go.estuary.dev/source-sentry",
    "resourcePathPointers": [
      "/name"
    ]
  }
]
