{
  "config_schema_json": {
    "$schema": "http://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/estuary/connectors/materialize-elasticsearch/config",
    "properties": {
      "credentials": {
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "apiKey": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "type": "object"
      },
      "endpoint": {
        "type": "string"
      },
      "hardDelete": {
        "type": "boolean"
      },
      "advanced": {
        "properties": {
          "number_of_replicas": {
            "type": "integer"
          }
        },
        "additionalProperties": false,
        "type": "object"
      },
      "networkTunnel": {
        "properties": {
          "sshForwarding": {
            "properties": {
              "sshEndpoint": {
                "type": "string"
              },
              "privateKey": {
                "type": "string"
              }
            },
            "additionalProperties": false,
            "type": "object",
            "required": [
              "sshEndpoint",
              "privateKey"
            ]
          }
        },
        "additionalProperties": false,
        "type": "object"
      }
    },
    "type": "object",
    "required": [
      "credentials",
      "endpoint"
    ],
    "title": "configSchema"
  },
  "resource_config_schema_json": {
    "$schema": "http://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/estuary/connectors/materialize-elasticsearch/resource",
    "properties": {
      "index": {
        "type": "string",
        "description": "Name of the Elasticsearch index to store the materialization results.",
        "x-collection-name": true
      },
      "delta_updates": {
        "type": "boolean",
        "description": "Should updates to this table be done via delta updates. Default is false.",
        "default": false,
        "x-delta-updates": true
      },
      "number_of_shards": {
        "type": "integer",
        "description": "The number of shards to create the index with. Leave blank to use the cluster default."
      }
    },
    "type": "object",
    "required": [
      "index",
      "delta_updates"
    ],
    "title": "resourceConfigSchema"
  },
  "documentation_url": "https://go.estuary.dev/materialize-elasticsearch"
}
